{
  "manifest_version": "2",
  "task_list": [
    {
      "name": "Cellpose SAM Segmentation",
      "category": "Segmentation",
      "tags": [
        "Deep Learning",
        "Convolutional Neural Network",
        "Instance Segmentation",
        "2D",
        "3D",
        "Cellpose",
        "SAM"
      ],
      "docs_info": "### Purpose\n- Description and documentation of the Task functionality\n- Bullet points that cover main features of the tasks.\n- Can use **full** *markdown* formatting (including embedding images).\n\n### Outputs\n- Optional section on what kind of outputs the task generates. For the thresholding_task: Generates a new label image named `label_name`.\n\n### Limitations\n- List known limitations of the task (e.g. only works for certain data types).",
      "type": "parallel",
      "executable_parallel": "cellpose_sam_segmentation_task.py",
      "meta_parallel": {
        "cpus_per_task": 4,
        "mem": 16000,
        "needs_gpu": true
      },
      "args_schema_parallel": {
        "$defs": {
          "AdvancedCellposeParameters": {
            "description": "Advanced Cellpose Model Parameters.",
            "properties": {
              "normalization": {
                "default": {
                  "mode": "default"
                },
                "discriminator": {
                  "mapping": {
                    "custom": "#/$defs/CustomNorm",
                    "default": "#/$defs/DefaultNorm",
                    "none": "#/$defs/NoNorm"
                  },
                  "propertyName": "mode"
                },
                "oneOf": [
                  {
                    "$ref": "#/$defs/DefaultNorm"
                  },
                  {
                    "$ref": "#/$defs/NoNorm"
                  },
                  {
                    "$ref": "#/$defs/CustomNorm"
                  }
                ],
                "title": "Normalization"
              },
              "batch_size": {
                "default": 8,
                "title": "Batch Size",
                "type": "integer"
              },
              "resample": {
                "default": true,
                "title": "Resample",
                "type": "boolean"
              },
              "invert": {
                "default": false,
                "title": "Invert",
                "type": "boolean"
              },
              "diameter": {
                "title": "Diameter",
                "type": "number"
              },
              "flow_threshold": {
                "default": 0.4,
                "title": "Flow Threshold",
                "type": "number"
              },
              "cellprob_threshold": {
                "default": 0.0,
                "title": "Cellprob Threshold",
                "type": "number"
              },
              "flow3D_smooth": {
                "default": 0,
                "title": "Flow3D Smooth",
                "type": "integer"
              },
              "anisotropy": {
                "title": "Anisotropy",
                "type": "number"
              },
              "do_3D": {
                "default": true,
                "title": "Do 3D",
                "type": "boolean"
              },
              "stitch_threshold": {
                "default": 0.0,
                "title": "Stitch Threshold",
                "type": "number"
              },
              "min_size": {
                "default": 15,
                "title": "Min Size",
                "type": "integer"
              },
              "max_size_fraction": {
                "default": 0.4,
                "title": "Max Size Fraction",
                "type": "number"
              },
              "niter": {
                "title": "Niter",
                "type": "integer"
              },
              "augment": {
                "default": false,
                "title": "Augment",
                "type": "boolean"
              },
              "tile_overlap": {
                "default": 0.1,
                "title": "Tile Overlap",
                "type": "number"
              },
              "bsize": {
                "default": 256,
                "title": "Bsize",
                "type": "integer"
              },
              "verbose": {
                "default": false,
                "title": "Verbose",
                "type": "boolean"
              }
            },
            "title": "AdvancedCellposeParameters",
            "type": "object"
          },
          "CellposeChannels": {
            "description": "Cellpose channels configuration.",
            "properties": {
              "mode": {
                "default": "label",
                "enum": [
                  "label",
                  "wavelength_id",
                  "index"
                ],
                "title": "Mode",
                "type": "string"
              },
              "identifiers": {
                "items": {
                  "type": "string"
                },
                "maxItems": 3,
                "minItems": 1,
                "title": "Identifiers",
                "type": "array"
              },
              "skip_if_missing": {
                "default": false,
                "title": "Skip If Missing",
                "type": "boolean"
              }
            },
            "required": [
              "identifiers"
            ],
            "title": "CellposeChannels",
            "type": "object"
          },
          "CreateMaskingRoiTable": {
            "description": "Create Masking ROI Table Configuration.",
            "properties": {
              "mode": {
                "const": "Create Masking ROI Table",
                "default": "Create Masking ROI Table",
                "title": "Mode",
                "type": "string"
              },
              "table_name": {
                "default": "{label_name}_masking_ROI_table",
                "title": "Table Name",
                "type": "string"
              }
            },
            "title": "CreateMaskingRoiTable",
            "type": "object"
          },
          "CustomNorm": {
            "description": "Custom Cellpose normalization.",
            "properties": {
              "mode": {
                "const": "custom",
                "default": "custom",
                "title": "Mode",
                "type": "string"
              },
              "normalize": {
                "default": true,
                "title": "Normalize",
                "type": "boolean"
              },
              "norm3D": {
                "default": false,
                "title": "Norm3D",
                "type": "boolean"
              },
              "invert": {
                "default": false,
                "title": "Invert",
                "type": "boolean"
              },
              "use_lowhigh": {
                "default": false,
                "title": "Use Lowhigh",
                "type": "boolean"
              },
              "lowhigh": {
                "default": [
                  0.0,
                  1000.0
                ],
                "maxItems": 2,
                "minItems": 2,
                "prefixItems": [
                  {
                    "type": "number"
                  },
                  {
                    "type": "number"
                  }
                ],
                "title": "Lowhigh",
                "type": "array"
              },
              "percentile": {
                "default": [
                  1.0,
                  99.0
                ],
                "maxItems": 2,
                "minItems": 2,
                "prefixItems": [
                  {
                    "type": "number"
                  },
                  {
                    "type": "number"
                  }
                ],
                "title": "Percentile",
                "type": "array"
              },
              "sharpen_radius": {
                "default": 0.0,
                "title": "Sharpen Radius",
                "type": "number"
              },
              "smooth_radius": {
                "default": 0.0,
                "title": "Smooth Radius",
                "type": "number"
              },
              "tile_norm_blocksize": {
                "default": 0,
                "title": "Tile Norm Blocksize",
                "type": "integer"
              },
              "tile_norm_smooth3D": {
                "default": 1,
                "title": "Tile Norm Smooth3D",
                "type": "integer"
              },
              "axis": {
                "default": -1,
                "title": "Axis",
                "type": "integer"
              }
            },
            "title": "CustomNorm",
            "type": "object"
          },
          "DefaultNorm": {
            "description": "Default Cellpose normalization.",
            "properties": {
              "mode": {
                "const": "default",
                "default": "default",
                "title": "Mode",
                "type": "string"
              }
            },
            "title": "DefaultNorm",
            "type": "object"
          },
          "GaussianBlurConfig": {
            "description": "Configuration for Gaussian blur transformation.",
            "properties": {
              "type": {
                "const": "Gaussian Blur Filter",
                "default": "Gaussian Blur Filter",
                "description": "Transformation type identifier for Gaussian blur filtering.",
                "title": "Type",
                "type": "string"
              },
              "sigma_xy": {
                "default": 2.0,
                "description": "Standard deviation for Gaussian kernel in XY plane.",
                "exclusiveMinimum": 0,
                "title": "Sigma XY",
                "type": "number"
              },
              "sigma_z": {
                "description": "Standard deviation for Gaussian kernel in Z axis.\nIf not specified, no blurring is applied in Z axis.",
                "title": "Sigma Z",
                "type": "number"
              }
            },
            "title": "GaussianBlurConfig",
            "type": "object"
          },
          "HistogramEqualizationConfig": {
            "description": "Configuration for Contrast Limited Adaptive Histogram Equalization (CLAHE).",
            "properties": {
              "type": {
                "const": "Histogram Equalization",
                "default": "Histogram Equalization",
                "description": "Transformation type identifier for histogram equalization.",
                "title": "Type",
                "type": "string"
              },
              "kernel_size_xy": {
                "description": "Shape of kernel in XY plane. If None, the default is 1/8 of image height by\n1/8 of its width.",
                "title": "Kernel Size XY",
                "type": "integer"
              },
              "kernel_size_z": {
                "description": "Shape of kernel in Z axis. If None, the default is 1/8 of image height by\n1/8 of its width.",
                "title": "Kernel Size Z",
                "type": "integer"
              },
              "clip_limit": {
                "default": 0.01,
                "description": "Clipping limit, normalized between 0 and 1 (higher values give more contrast).",
                "maximum": 1,
                "minimum": 0,
                "title": "Clip Limit",
                "type": "number"
              },
              "nbins": {
                "default": 256,
                "description": "Number of gray bins for histogram (\"data range\").",
                "title": "Nbins",
                "type": "integer"
              }
            },
            "title": "HistogramEqualizationConfig",
            "type": "object"
          },
          "IteratorConfig": {
            "description": "Advanced iterator configuration.",
            "properties": {
              "masking": {
                "$ref": "#/$defs/MaskingConfig",
                "description": "If set, the segmentation will be performed only within the confines of\nthe specified mask. A mask can be specified either by a label image or a\nMasking ROI table.",
                "title": "Masking Iterator Configuration"
              },
              "roi_table": {
                "description": "Name of a ROI table. If set, the segmentation will be applied to each ROI\nin the table individually. This option can be combined with masking.",
                "title": "Iterate Over ROIs",
                "type": "string"
              }
            },
            "title": "IteratorConfig",
            "type": "object"
          },
          "MaskingConfig": {
            "description": "Masking configuration.",
            "properties": {
              "mode": {
                "default": "Table Name",
                "description": "Mode of masking to be applied.\n    - If \"Table Name\", the identifier refers to a masking table name.\n    - If \"Label Name\", the identifier refers to a label image name.",
                "enum": [
                  "Table Name",
                  "Label Name"
                ],
                "title": "Mode",
                "type": "string"
              },
              "identifier": {
                "description": "Name of the masking table or label image depending on the mode.",
                "title": "Identifier",
                "type": "string"
              }
            },
            "title": "MaskingConfig",
            "type": "object"
          },
          "MedianFilterConfig": {
            "description": "Configuration for Median filter transformation.",
            "properties": {
              "type": {
                "const": "Median Filter",
                "default": "Median Filter",
                "description": "Transformation type identifier for median filtering.",
                "title": "Type",
                "type": "string"
              },
              "size_xy": {
                "default": 2,
                "description": "Size in pixels of the median filter in XY plane.",
                "exclusiveMinimum": 0,
                "title": "Size XY",
                "type": "integer"
              },
              "size_z": {
                "description": "Size in pixels of the median filter in Z axis.\nIf not specified, no filtering is applied in Z axis.",
                "title": "Size Z",
                "type": "integer"
              }
            },
            "title": "MedianFilterConfig",
            "type": "object"
          },
          "NoNorm": {
            "description": "Disable Cellpose normalization.",
            "properties": {
              "mode": {
                "const": "none",
                "default": "none",
                "title": "Mode",
                "type": "string"
              }
            },
            "title": "NoNorm",
            "type": "object"
          },
          "SegmentationTransformConfig": {
            "description": "Configuration for pre- and post-processing steps.",
            "properties": {
              "pre_process": {
                "default": [],
                "description": "List of pre-processing steps to be applied before segmentation.",
                "items": {
                  "discriminator": {
                    "mapping": {
                      "Gaussian Blur Filter": "#/$defs/GaussianBlurConfig",
                      "Histogram Equalization": "#/$defs/HistogramEqualizationConfig",
                      "Median Filter": "#/$defs/MedianFilterConfig"
                    },
                    "propertyName": "type"
                  },
                  "oneOf": [
                    {
                      "$ref": "#/$defs/GaussianBlurConfig"
                    },
                    {
                      "$ref": "#/$defs/MedianFilterConfig"
                    },
                    {
                      "$ref": "#/$defs/HistogramEqualizationConfig"
                    }
                  ]
                },
                "title": "Pre Process",
                "type": "array"
              },
              "post_process": {
                "default": [],
                "description": "List of post-processing steps to be applied after segmentation.",
                "items": {
                  "discriminator": {
                    "mapping": {
                      "Size Filter": "#/$defs/SizeFilterConfig"
                    },
                    "propertyName": "type"
                  },
                  "oneOf": [
                    {
                      "$ref": "#/$defs/SizeFilterConfig"
                    }
                  ]
                },
                "title": "Post Process",
                "type": "array"
              }
            },
            "title": "SegmentationTransformConfig",
            "type": "object"
          },
          "SizeFilterConfig": {
            "description": "Configuration for size filter post-processing.",
            "properties": {
              "type": {
                "const": "Size Filter",
                "default": "Size Filter",
                "description": "Transformation type identifier for size filtering.",
                "title": "Type",
                "type": "string"
              },
              "min_size": {
                "description": "Minimum size in pixels for objects to keep.\nObjects smaller than this size will be removed.",
                "minimum": 0,
                "title": "Min Size",
                "type": "integer"
              }
            },
            "required": [
              "min_size"
            ],
            "title": "SizeFilterConfig",
            "type": "object"
          },
          "SkipCreateMaskingRoiTable": {
            "description": "Skip Creating Masking ROI Table Configuration.",
            "properties": {
              "mode": {
                "const": "Skip Creating Masking ROI Table",
                "default": "Skip Creating Masking ROI Table",
                "title": "Mode",
                "type": "string"
              }
            },
            "title": "SkipCreateMaskingRoiTable",
            "type": "object"
          }
        },
        "additionalProperties": false,
        "properties": {
          "zarr_url": {
            "title": "Zarr Url",
            "type": "string",
            "description": "URL to the OME-Zarr container"
          },
          "channels": {
            "$ref": "#/$defs/CellposeChannels",
            "title": "Channels",
            "description": "Channels to use for segmentation. It must contain between 1 and 3 channel identifiers."
          },
          "label_name": {
            "default": "{channel_identifier}_segmented",
            "title": "Label Name",
            "type": "string",
            "description": "Name of the resulting label image. Optionally, it can contain a placeholder \"{channel_identifier}\" which will be replaced by the first channel identifier specified in the channels parameter."
          },
          "level_path": {
            "title": "Level Path",
            "type": "string",
            "description": "If the OME-Zarr has multiple resolution levels, the level to use can be specified here. If not provided, the highest resolution level will be used."
          },
          "iterator_configuration": {
            "$ref": "#/$defs/IteratorConfig",
            "title": "Iterator Configuration",
            "description": "Configuration for the segmentation iterator. This can be used to specify masking and/or a ROI table."
          },
          "custom_model": {
            "title": "Custom Model",
            "type": "string",
            "description": "Path to a custom Cellpose model. If not set, the default \"cpsam\" model will be used."
          },
          "advanced_parameters": {
            "$ref": "#/$defs/AdvancedCellposeParameters",
            "default": {
              "normalization": {
                "mode": "default"
              },
              "batch_size": 8,
              "resample": true,
              "invert": false,
              "diameter": null,
              "flow_threshold": 0.4,
              "cellprob_threshold": 0.0,
              "flow3D_smooth": 0,
              "anisotropy": null,
              "do_3D": true,
              "stitch_threshold": 0.0,
              "min_size": 15,
              "max_size_fraction": 0.4,
              "niter": null,
              "augment": false,
              "tile_overlap": 0.1,
              "bsize": 256,
              "verbose": false
            },
            "title": "Advanced Parameters",
            "description": "Advanced parameters for Cellpose segmentation."
          },
          "pre_post_process": {
            "$ref": "#/$defs/SegmentationTransformConfig",
            "default": {
              "pre_process": [],
              "post_process": []
            },
            "title": "Pre Post Process",
            "description": "Configuration for pre- and post-processing transforms applied by the iterator."
          },
          "create_masking_roi_table": {
            "default": {
              "mode": "Skip Creating Masking ROI Table"
            },
            "discriminator": {
              "mapping": {
                "Create Masking ROI Table": "#/$defs/CreateMaskingRoiTable",
                "Skip Creating Masking ROI Table": "#/$defs/SkipCreateMaskingRoiTable"
              },
              "propertyName": "mode"
            },
            "oneOf": [
              {
                "$ref": "#/$defs/CreateMaskingRoiTable"
              },
              {
                "$ref": "#/$defs/SkipCreateMaskingRoiTable"
              }
            ],
            "title": "Create Masking Roi Table",
            "description": "Configuration to create a masking ROI table after segmentation."
          },
          "overwrite": {
            "default": true,
            "title": "Overwrite",
            "type": "boolean",
            "description": "Whether to overwrite an existing label image. Defaults to True."
          }
        },
        "required": [
          "zarr_url",
          "channels"
        ],
        "type": "object",
        "title": "CellposeSamSegmentationTask"
      },
      "docs_link": "https://github.com/fractal-analytics-platform/fractal-cellpose-sam-task"
    }
  ],
  "has_args_schemas": true,
  "args_schema_version": "pydantic_v2",
  "authors": "Lorenzo Cerrone"
}
